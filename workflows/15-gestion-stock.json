    {
      "parameters": {
        "jsCode": "const data = $('Calcul Nouveau Stock').first().json;\nconst msg = `🚨 *ALERTE STOCK BAS* — Volet Roulant\\n` +\n  `📦 *${data.designation_stock}*\\n` +\n  `Stock actuel : *${data.stock_apres}* restants\\n` +\n  `Seuil minimum : ${data.seuil_min}\\n` +\n  `Emplacement : ${data.emplacement}\\n` +\n  `Mouvement : ${data.action} de ${data.delta} unité(s)\\n` +\n  `Bon prod : ${data.bon_id}\\n` +\n  `Timestamp : ${new Date(data.timestamp).toLocaleString('fr-FR')}\\n\\n` +\n  `👉 Lancer réapprovisionnement`;\n\nconst emailBody = `<h2>⚠️ Alerte Stock Bas — Volet Roulant</h2>\\n` +\n  `<table border='1' cellpadding='8' style='border-collapse:collapse'>\\n` +\n  `<tr><th>Désignation</th><td>${data.designation_stock}</td></tr>\\n` +\n  `<tr><th>Stock actuel</th><td><strong style='color:red'>${data.stock_apres}</strong></td></tr>\\n` +\n  `<tr><th>Seuil minimum</th><td>${data.seuil_min}</td></tr>\\n` +\n  `<tr><th>Emplacement</th><td>${data.emplacement}</td></tr>\\n` +\n  `<tr><th>Mouvement</th><td>${data.action} × ${data.delta}</td></tr>\\n` +\n  `<tr><th>Bon production</th><td>${data.bon_id}</td></tr>\\n` +\n  `</table>\\n` +\n  `<p><em>Réapprovisionner auprès du fournisseur.</em></p>`;\n\nreturn [{ json: {\n  ...data,\n  slack_msg: msg,\n  email_body: emailBody,\n  email_subject: `Réappro volet ${data.designation_stock} : ${data.stock_apres} restants`\n}}];"
      },
