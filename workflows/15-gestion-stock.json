    {
      "parameters": {
        "jsCode": "// Merge produit data with scan params\nconst scan = $('Has Bon ID?').first().json;\nconst produitItem = $input.first();\nconst produit = produitItem?.json?.fields || produitItem?.json || {};\nconst produitId = produitItem?.json?.id || '';\n\nif (!produitId) {\n  return [{ json: {\n    ...scan,\n    found: false,\n    error: `Produit non trouvé pour bon_id: ${scan.bon_id}`\n  }}];\n}\n\nconst categorie = produit.Categorie || '';\nconst isVolet = categorie.toLowerCase().includes('volet');\n\nreturn [{ json: {\n  ...scan,\n  found: true,\n  produit_record_id: produitId,\n  designation: produit.Designation || 'N/A',\n  categorie,\n  is_volet: isVolet,\n  quantite_produit: produit.Quantite || scan.qte || 1,\n  statut_prod: produit.statut_production || 'N/A',\n  statut_val: produit.statut_validation || 'N/A'\n}}];"
      },
      "id": "4679630e-b3aa-42d1-9372-e65f3e4abcf5",
      "name": "Merge Produit Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
