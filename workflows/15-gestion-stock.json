      "parameters": {
        "jsCode": "// Validate token against env var\nconst token = $json.token || '';\nconst validToken = $env.STOCK_WEBHOOK_TOKEN || 'ABC';\n\nif (token !== validToken) {\n  return [{ json: { ...($json), valid: false, error: 'Token invalide' } }];\n}\nreturn [{ json: { ...($json), valid: true } }];"
      },
