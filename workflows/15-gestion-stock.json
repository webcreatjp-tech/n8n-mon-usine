    {
      "parameters": {
        "jsCode": "const scan = $('Est Volet Roulant?').first().json;\nconst stockItem = $input.first();\nconst stockFields = stockItem?.json?.fields || {};\nconst stockRecordId = stockItem?.json?.id || null;\n\nconst qteActuelle = stockFields.QuantiteDisponible ?? 0;\nconst seuilMin = stockFields.SeuilMin ?? 2;\nconst action = scan.action;\nconst delta = parseInt(scan.quantite_produit || scan.qte || 1, 10);\n\nlet nouvelleQte;\nif (action === 'decrement') {\n  nouvelleQte = Math.max(0, qteActuelle - delta);\n} else if (action === 'increment') {\n  nouvelleQte = qteActuelle + delta;\n} else {\n  // 'view' only\n  nouvelleQte = qteActuelle;\n}\n\nconst stockBas = nouvelleQte < seuilMin;\n\nreturn [{ json: {\n  ...scan,\n  stock_record_id: stockRecordId,\n  stock_avant: qteActuelle,\n  stock_apres: nouvelleQte,\n  seuil_min: seuilMin,\n  delta,\n  stock_bas: stockBas,\n  emplacement: stockFields.Emplacement || 'Atelier',\n  needs_update: action === 'decrement' || action === 'increment',\n  designation_stock: stockFields.Designation?.[0] || scan.designation || 'N/A'\n}}];"
      },
