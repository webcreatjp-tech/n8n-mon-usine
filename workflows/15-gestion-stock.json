    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst stocks = items.map(item => {\n  const f = item.json.fields || {};\n  return {\n    id: item.json.id,\n    designation: f.Designation || f['Designation (from ProduitID)']?.[0] || 'N/A',\n    categorie: f.Categorie || f['Categorie (from ProduitID)']?.[0] || 'N/A',\n    quantite: f.QuantiteDisponible ?? 0,\n    seuil: f.SeuilMin ?? 2,\n    emplacement: f.Emplacement || 'N/A',\n    dernier_mvt: f.DernierMvt || null,\n    alerte: f.StockAlerte || '⚠️ BAS'\n  };\n});\n\nreturn [{\n  json: {\n    success: true,\n    action: 'list',\n    count: stocks.length,\n    stocks,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
